# ── Local development (SQLite) ──────────────────────────────
DB_DRIVER=sqlite
DATABASE_URL=sqlite://starbound.db

JWT_SECRET=dev-secret-change-in-prod-32characters
HOST=127.0.0.1
PORT=3000

# Base tick: 60 000 ms = 1 real minute per game tick at x1 speed
TICK_MS=60000

# Starting speed (1=real-time, 2/5/10/100 for local testing)
GAME_SPEED=5

# Allow players to change speed via the UI (true for local, false for public)
ALLOW_PLAYER_SPEED=true

CORS_ORIGIN=http://localhost:5173
